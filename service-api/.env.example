# backtest-engine environment overrides.
#
# Copy to `.env` and fill in secrets.  All fields are optional EXCEPT
# DEEPSEEK_API_KEY if you want to enable Gate 2 AI code review.
#
# Env-var names follow SERVICE_API_<SECTION>_<KEY> (see internal/config/config.go
# for the applyEnvOverrides list).

# --- Gate 2 AI code review ---
# Obtain at https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Set to "true" to turn on Gate 2 once a key is provided.  Fail-closed:
# if enabled=true but the key is missing, submissions 503 with AI_REVIEW_UNAVAILABLE.
SERVICE_API_AI_REVIEW_ENABLED=false

# Optional overrides (sensible defaults apply if omitted):
# SERVICE_API_AI_REVIEW_MODEL=deepseek-reasoner
# SERVICE_API_AI_REVIEW_TIMEOUT_SECONDS=30
# SERVICE_API_AI_REVIEW_CACHE_TTL_DAYS=30

# --- sandbox-service dispatch ---
# Only override in non-default topologies.
# SERVICE_API_SANDBOX_SERVICE_URL=http://sandbox-service:8090

# --- DB (override for local dev; docker-compose already sets these) ---
# SERVICE_API_DATABASE_HOST=localhost
# SERVICE_API_DATABASE_USER=claw
# SERVICE_API_DATABASE_PASSWORD=claw
