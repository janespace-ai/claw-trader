# desktop-client environment overrides (Vite + Electron)
#
# Copy this file to `.env.local` (gitignored) to customise your local
# build without touching the committed defaults:
#
#   cp .env.example .env.local
#
# All VITE_-prefixed variables are baked into the renderer bundle at
# build time. They are NOT readable at runtime from arbitrary installs
# — for per-install overrides, drop a claw-config.json into Electron's
# userData directory instead (see CONFIGURATION.md).

# Backtest-engine / data-gateway base URL. Used as the initial default
# when no user override is persisted and no claw-config.json exists.
# Example alternatives:
#   VITE_REMOTE_BASE_URL=http://10.0.0.5:8081
#   VITE_REMOTE_BASE_URL=https://claw.yourcompany.internal
VITE_REMOTE_BASE_URL=http://localhost:8081
