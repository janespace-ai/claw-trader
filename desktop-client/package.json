{
  "name": "claw-trader-desktop",
  "version": "0.1.0",
  "description": "Claw Trader desktop client — AI-driven crypto strategy design and backtesting",
  "main": "dist-electron/main.mjs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && electron-builder",
    "build:renderer": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src electron --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:browser": "CLAW_BROWSER_ONLY=1 vite --port 5173",
    "dev:mock": "VITE_USE_MOCKS=1 vite",
    "api:lint": "node scripts/api-lint.mjs",
    "api:types": "node scripts/gen-api-types.mjs",
    "api:mocks": "node scripts/gen-msw-handlers.mjs",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "test:visual:ui": "playwright test --ui",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@google/generative-ai": "^0.21.0",
    "better-sqlite3": "^11.5.0",
    "i18next": "^23.16.5",
    "i18next-browser-languagedetector": "^8.0.0",
    "lightweight-charts": "^5.2.0",
    "openai": "^4.70.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.1",
    "technicalindicators": "^3.1.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/ui": "^2.1.9",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.15.0",
    "eslint-plugin-claw": "file:./eslint-plugin-claw",
    "js-yaml": "^4.1.1",
    "jsdom": "^25.0.1",
    "msw": "^2.13.4",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "com.janespace.claw-trader",
    "productName": "Claw Trader",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.finance"
    },
    "win": {
      "target": "nsis"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-builder",
      "better-sqlite3",
      "esbuild"
    ]
  }
}
